		{
			"name": "01 — Authentification",
			"description": "Inscription, connexion, profil utilisateur, refresh token, déconnexion.",
			"item": [
				{
					"name": "Register — Candidat (succès)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token_candidat', json.token);",
									"    pm.test('Candidat registered & token saved', function () {",
									"        pm.expect(json.token).to.be.a('string');",
									"        pm.expect(json.user.role).to.eql('candidat');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Candidat Test\",\n    \"email\": \"candidat@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"candidat\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					}
				},
